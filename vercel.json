{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "redirects": [
    {
      "source": "/",
      "destination": "/landing",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/landing",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    }
  ]
}
